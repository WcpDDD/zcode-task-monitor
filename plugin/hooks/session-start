#!/usr/bin/env bash
# SessionStart hook for the task-monitor plugin.
#
# Its only job: make sure the ZCodeTaskMonitor menu-bar app is running, then
# return immediately so it never blocks ZCode startup. The hook itself is a
# short-lived process (per ZCode's hook contract), so we hand off to a
# detached background launcher and exit.
set -euo pipefail

APP_NAME="ZCodeTaskMonitor"
APP_BUNDLE_NAME="ZCodeTaskMonitor.app"

# Resolve the plugin root. ZCode/Claude Code exposes it via env var.
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-${ZCODE_PLUGIN_ROOT:-}}"
if [[ -z "$PLUGIN_ROOT" ]]; then
  PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
fi

# Find the .app: prefer plugin's own dist, then /Applications, then ~/Applications.
find_app() {
  local candidates=(
    "$PLUGIN_ROOT/dist/$APP_BUNDLE_NAME"
    "/Applications/$APP_BUNDLE_NAME"
    "$HOME/Applications/$APP_BUNDLE_NAME"
  )
  for c in "${candidates[@]}"; do
    if [[ -d "$c" ]]; then
      printf '%s' "$c"
      return 0
    fi
  done
  return 1
}

# Idempotent launch: only start if the app process is NOT already running.
launch_if_needed() {
  # pgrep matches the executable name inside the bundle.
  if pgrep -fl "/MacOS/$APP_NAME" >/dev/null 2>&1; then
    return 0
  fi

  local app
  if ! app="$(find_app)"; then
    # App not found — nothing we can do; stay silent so we don't spam the session.
    return 0
  fi

  # `open` launches the app asynchronously and returns immediately.
  /usr/bin/open -a "$app" >/dev/null 2>&1 || true
}

# Hand off to a detached subshell so this hook process exits right away.
( launch_if_needed >/dev/null 2>&1 & ) 2>/dev/null || true

# Hooks may emit JSON to inject context; we inject nothing and exit 0.
printf '{}\n'
exit 0
